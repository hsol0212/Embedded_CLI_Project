  PRE_LINK = cd .
  TARGET_FILE = stm32f_cli.elf
  TARGET_PDB = stm32f_cli.elf.dbg
  TARGET_SUPPORT_DIR = CMakeFiles\stm32f_cli.dir


#############################################
# Utility command for edit_cache

build CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D D:\stm_proj\stm32f_cli\build\Debug && C:\Users\2\AppData\Local\stm32cube\bundles\cmake\4.2.3+st.1\bin\cmake-gui.exe -SD:\stm_proj\stm32f_cli -BD:\stm_proj\stm32f_cli\build\Debug"
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build edit_cache: phony CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D D:\stm_proj\stm32f_cli\build\Debug && C:\Users\2\AppData\Local\stm32cube\bundles\cmake\4.2.3+st.1\bin\cmake.exe --regenerate-during-build -SD:\stm_proj\stm32f_cli -BD:\stm_proj\stm32f_cli\build\Debug"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build rebuild_cache: phony CMakeFiles/rebuild_cache.util

